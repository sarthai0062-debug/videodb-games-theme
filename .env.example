VIDEO_DB_API_KEY=your-api-key-here

# Hackathon collection (all VideoDB assets go here — visible in Console)
# List yours: python -c "import videodb; from dotenv import load_dotenv; load_dotenv(); [print(c.id, c.name) for c in videodb.connect().get_collections()]"
VIDEODB_COLLECTION_ID=c-your-collection-id
VIDEODB_COLLECTION_NAME=new collection

# Per-move media (default: economy — no generative calls during play)
# economy | voice | image | video
# For demos: image generates an AI board still per turn (shown in UI + collection)
VIDEODB_MEDIA_MODE=economy

# Video mode only — API requires 5–8s to generate; playback can be trimmed shorter
# VIDEODB_VIDEO_DURATION=3
# VIDEODB_VIDEO_GENERATE_SEC=5
# VIDEODB_VIDEO_PLAYBACK_SEC=3

# Recap (default: local — free browser slideshow, zero VideoDB credits)
# local | cloud  (cloud = VideoDB Timeline compile, costs credits)
VIDEODB_RECAP=local

# Scene index model for play-by-play (index_scenes model_name)
# basic | pro | ultra
VIDEODB_SCENE_MODEL=basic

# Sandbox compute (hackathon — https://hackday.videodb.io/sandbox.html)
# small ($1/hr) | medium ($3.50/hr) — medium required for FLUX + recap
VIDEODB_SANDBOX_TIER=medium
VIDEODB_SANDBOX_IDLE_TIMEOUT=600
# Set true on Render (auto in render.yaml) — FLUX runs in background to avoid 30s HTTP timeout
# SANDBOX_ASYNC_FLUX=true
# VIDEODB_SANDBOX_FLUX_SIZE=1280x720
# VIDEODB_SANDBOX_FLUX_STEPS=28

# --- Production (Render API + Vercel frontend) ---
# Render: SERVE_STATIC=false, CORS_ORIGINS=https://your-app.vercel.app
# Vercel: VIDEODB_API_BASE=https://your-api.onrender.com
# SERVE_STATIC=false
# CORS_ORIGINS=https://your-app.vercel.app
